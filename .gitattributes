# Auto detect text files and normalize line endings to LF
* text=auto

# C++ source files
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cc text eol=lf
*.cxx text eol=lf

# Build files
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf